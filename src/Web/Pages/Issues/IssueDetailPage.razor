@namespace Web.Pages.Issues
@page "/issues/{Id}"
@inject IIssueApiClient IssueClient
@inject ICommentApiClient CommentClient
@inject NavigationManager Nav

<PageTitle>@(_issue?.Title ?? "Issue") — IssueManager</PageTitle>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
	@if (_isLoading)
	{
		<LoadingSpinner />
	}
	else if (_issue == null)
	{
		<div class="text-center py-12 text-[var(--text-muted)]">
			<p class="text-lg mb-4">Issue not found.</p>
			<a href="/issues" class="text-[var(--color-primary)] hover:underline">Back to Issues</a>
		</div>
	}
	else
	{
		<!-- Header -->
		<div class="mb-6">
			<div class="flex items-start justify-between mb-4">
				<div class="flex-1">
					<h1 class="text-3xl font-bold text-[var(--text-main)] mb-2">@_issue.Title</h1>
					<div class="flex items-center gap-3 text-sm text-[var(--text-muted)]">
						<span>Created by <strong>@_issue.Author.Name</strong></span>
						<span>•</span>
						<span>@_issue.DateCreated.ToString("MMMM dd, yyyy")</span>
					</div>
				</div>
				<a href="/issues/@Id/edit" class="px-4 py-2 border border-[var(--border-color)] text-[var(--text-main)] rounded-lg hover:bg-[var(--bg-hover)] transition-colors text-sm font-medium">
					Edit Issue
				</a>
			</div>
			<div class="flex items-center gap-3">
				<StatusBadge Status="@_issue.Status" />
				<span class="text-sm text-[var(--text-muted)]">Category: <strong>@_issue.Category.CategoryName</strong></span>
			</div>
		</div>

		<!-- Description -->
		<div class="bg-[var(--bg-surface)] rounded-2xl border border-[var(--border-color)] shadow-sm p-6 mb-8">
			<h2 class="text-lg font-semibold text-[var(--text-main)] mb-3">Description</h2>
			@if (string.IsNullOrWhiteSpace(_issue.Description))
			{
				<p class="text-[var(--text-muted)] italic">No description provided.</p>
			}
			else
			{
				<p class="text-[var(--text-main)] whitespace-pre-wrap">@_issue.Description</p>
			}
		</div>

		<!-- Comments section -->
		<div class="bg-[var(--bg-surface)] rounded-2xl border border-[var(--border-color)] shadow-sm p-6">
			<h2 class="text-lg font-semibold text-[var(--text-main)] mb-4">Comments (@_comments.Count())</h2>

			@if (!_comments.Any())
			{
				<p class="text-[var(--text-muted)] italic mb-6">No comments yet. Be the first to comment!</p>
			}
			else
			{
				<div class="space-y-4 mb-6">
					@foreach (var comment in _comments)
					{
						<div class="border-l-2 border-[var(--border-color)] pl-4 py-2">
							<div class="flex items-center gap-2 text-sm text-[var(--text-muted)] mb-1">
								<strong>@comment.Author.Name</strong>
								<span>•</span>
								<span>@comment.DateCreated.ToString("MMM dd, yyyy HH:mm")</span>
							</div>
							<p class="text-[var(--text-main)] whitespace-pre-wrap">@comment.Description</p>
						</div>
					}
				</div>
			}

			<!-- Add comment form -->
			<div>
				<label for="comment-text" class="block text-sm font-medium text-[var(--text-main)] mb-1.5">Add a comment</label>
				<textarea
					id="comment-text"
					@bind="_newCommentText"
					class="form-input resize-y"
					rows="4"
					placeholder="Write your comment here..."
					disabled="@_isSubmittingComment"></textarea>
				<button
					@onclick="AddComment"
					disabled="@(string.IsNullOrWhiteSpace(_newCommentText) || _isSubmittingComment)"
					class="mt-3 px-4 py-2 bg-[var(--color-primary)] text-white rounded-lg hover:opacity-90 transition-opacity text-sm font-medium disabled:opacity-60 disabled:cursor-not-allowed">
					@(_isSubmittingComment ? "Posting..." : "Post Comment")
				</button>
			</div>
		</div>

		<!-- Back link -->
		<div class="mt-6">
			<a href="/issues" class="text-[var(--color-primary)] hover:underline text-sm">← Back to Issues</a>
		</div>
	}
</div>

@code {
	/// <summary>
	/// The ID of the issue to display.
	/// </summary>
	[Parameter]
	public string Id { get; set; } = "";

	private IssueDto? _issue;
	private IEnumerable<CommentDto> _comments = [];
	private bool _isLoading = true;
	private string _newCommentText = "";
	private bool _isSubmittingComment = false;

	/// <summary>
	/// Loads the issue and its comments on initialization.
	/// </summary>
	protected override async Task OnInitializedAsync()
	{
		_isLoading = true;
		try
		{
			_issue = await IssueClient.GetByIdAsync(Id);
			if (_issue != null)
			{
				_comments = await CommentClient.GetAllAsync();
				// TODO: Filter comments by issue ID when API supports it
			}
		}
		finally
		{
			_isLoading = false;
		}
	}

	/// <summary>
	/// Adds a new comment to the issue.
	/// </summary>
	private async Task AddComment()
	{
		if (string.IsNullOrWhiteSpace(_newCommentText) || _issue == null) return;

		_isSubmittingComment = true;
		try
		{
			var command = new CreateCommentCommand
			{
				Title = "Comment",
				CommentText = _newCommentText,
				IssueId = Id
			};
			var newComment = await CommentClient.CreateAsync(command);
			if (newComment != null)
			{
				_comments = _comments.Append(newComment);
				_newCommentText = "";
			}
		}
		finally
		{
			_isSubmittingComment = false;
		}
	}
}
