@namespace Web.Pages.Categories
@page "/categories"
@attribute [StreamRendering]
@attribute [Authorize(Roles = "Admin")]
@inject ICategoryApiClient CategoryClient

<PageTitle>Categories — IssueManager</PageTitle>

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
	<div class="flex items-center justify-between mb-6">
		<h1 class="text-2xl font-bold text-[var(--text-main)]">Categories</h1>
		<a href="/categories/create" class="px-4 py-2 bg-[var(--color-primary)] text-white rounded-lg hover:opacity-90 transition-opacity text-sm font-medium">
			New Category
		</a>
	</div>

	<DataTable Items="_categories" IsLoading="_isLoading" EmptyMessage="No categories found." TItem="CategoryDto">
		<HeaderContent>
			<th scope="col" class="px-6 py-3">Name</th>
			<th scope="col" class="px-6 py-3">Description</th>
			<th scope="col" class="px-6 py-3 text-right">Actions</th>
		</HeaderContent>
		<RowContent>
			<tr class="bg-[var(--bg-surface)] hover:bg-[var(--bg-hover)] transition-colors">
				<td class="px-6 py-4 font-medium text-[var(--text-main)]">@context.CategoryName</td>
				<td class="px-6 py-4 text-[var(--text-muted)]">@(string.IsNullOrWhiteSpace(context.CategoryDescription) ? "—" : context.CategoryDescription)</td>
				<td class="px-6 py-4 text-right">
					<div class="inline-flex items-center gap-3">
						<a href="/categories/@context.Id.ToString()/edit" class="text-[var(--color-primary)] hover:underline text-sm">
							Edit
						</a>
						<button @onclick="() => ShowDeleteConfirm(context)" class="text-red-600 hover:underline text-sm">
							Delete
						</button>
					</div>
				</td>
			</tr>
		</RowContent>
	</DataTable>

	<ConfirmDialog
		IsVisible="_showDeleteDialog"
		Title="Delete Category"
		Message="@($"Are you sure you want to delete the category \"{_categoryToDelete?.CategoryName}\"? This action cannot be undone.")"
		ConfirmText="Delete"
		CancelText="Cancel"
		OnConfirm="ConfirmDelete"
		OnCancel="CancelDelete" />
</div>

@code {
	private IEnumerable<CategoryDto> _categories = [];
	private bool _isLoading = true;
	private bool _showDeleteDialog = false;
	private CategoryDto? _categoryToDelete;

	/// <summary>
	/// Loads all categories on initialization.
	/// </summary>
	protected override async Task OnInitializedAsync()
	{
		_isLoading = true;
		try
		{
			_categories = await CategoryClient.GetAllAsync();
		}
		finally
		{
			_isLoading = false;
		}
	}

	/// <summary>
	/// Shows the delete confirmation dialog for a category.
	/// </summary>
	private void ShowDeleteConfirm(CategoryDto category)
	{
		_categoryToDelete = category;
		_showDeleteDialog = true;
	}

	/// <summary>
	/// Confirms the deletion of the category and reloads the list.
	/// </summary>
	private async Task ConfirmDelete()
	{
		if (_categoryToDelete != null)
		{
			await CategoryClient.DeleteAsync(_categoryToDelete.Id.ToString());
			_categories = await CategoryClient.GetAllAsync();
		}
		_showDeleteDialog = false;
		_categoryToDelete = null;
	}

	/// <summary>
	/// Cancels the deletion and closes the confirmation dialog.
	/// </summary>
	private void CancelDelete()
	{
		_showDeleteDialog = false;
		_categoryToDelete = null;
	}
}
