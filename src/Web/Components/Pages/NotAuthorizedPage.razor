@page "/not-authorized"

<PageTitle>Not Authorized — IssueManager</PageTitle>

<div class="max-w-2xl mx-auto px-4 sm:px-6 lg:px-8 py-16 text-center">
	<div class="mb-6">
		<svg class="w-16 h-16 mx-auto text-[var(--color-primary)] opacity-60" fill="none" stroke="currentColor"
		     viewBox="0 0 24 24" aria-hidden="true">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5"
			      d="M12 15v2m0 0v2m0-2h2m-2 0H10m2-10a4 4 0 100 8 4 4 0 000-8zm0 0V5m0 0H9m3 0h3"/>
		</svg>
	</div>
	<h1 class="text-3xl font-bold text-[var(--text-main)] mb-4">Access Denied</h1>
	<p class="text-[var(--text-muted)] mb-8">
		You don't have permission to access this page.
		Contact your administrator if you believe this is an error.
	</p>
	<div class="flex items-center justify-center gap-4">
		<a href="/"
		   class="px-6 py-3 bg-[var(--color-primary)] text-white rounded-lg hover:opacity-90 transition-opacity text-sm font-medium">
			Go to Home
		</a>
		<a href="/issues"
		   class="px-6 py-3 border border-[var(--border-color)] text-[var(--text-main)] rounded-lg hover:bg-[var(--bg-hover)] transition-colors text-sm font-medium">
			View Issues
		</a>
	</div>
</div>
