@page "/statuses/{Id}/edit"

@attribute [Authorize(Roles = "Admin")]
@inject IStatusApiClient StatusClient
@inject NavigationManager Nav

<PageTitle>Edit Status — IssueManager</PageTitle>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
	@if (_isLoadingStatus)
	{
		<LoadingSpinner />
	}
	else if (_status == null)
	{
		<div class="loading-state">
			<p class="text-lg mb-4">Status not found.</p>
			<a href="/statuses" class="link-primary">Back to Statuses</a>
		</div>
	}
	else
	{
		<div class="mb-6">
			<h1 class="page-title mb-2">Edit Status</h1>
			<p class="text-[var(--text-muted)] text-sm">Update the status details below.</p>
		</div>

		<div class="card">
			<EditForm Model="@_formModel" OnValidSubmit="@HandleSubmit">
				<DataAnnotationsValidator />
				<ValidationSummary class="validation-summary" />

				<div class="space-y-5">
					<!-- Name -->
					<div>
						<label for="status-name" class="form-label">
							Status Name <span class="text-red-500" aria-hidden="true">*</span>
						</label>
						<InputText id="status-name" @bind-Value="_formModel.StatusName" class="form-input"
											 placeholder="Enter status name" aria-required="true" />
						<ValidationMessage For="@(() => _formModel.StatusName)" class="validation-message" />
					</div>

					<!-- Description -->
					<div>
						<label for="status-description" class="form-label">
							Description
						</label>
						<InputTextArea id="status-description" @bind-Value="_formModel.StatusDescription" class="form-input resize-y"
													 rows="3" placeholder="Enter status description (optional)" />
						<ValidationMessage For="@(() => _formModel.StatusDescription)" class="validation-message" />
					</div>
				</div>

				<!-- Actions -->
				<div class="mt-6 flex items-center gap-3">
					<button type="submit" class="btn-action" disabled="@_isSubmitting">
						@(_isSubmitting ? "Updating..." : "Update Status")
					</button>
					<a href="/statuses" class="btn-ghost">
						Cancel
					</a>
				</div>
			</EditForm>
		</div>
	}
</div>

@code {
	/// <summary>
	/// The ID of the status to edit.
	/// </summary>
	[Parameter]
	public string Id { get; set; } = "";

	private StatusDto? _status;
	private StatusFormModel _formModel = new();
	private bool _isLoadingStatus = true;
	private bool _isSubmitting = false;

	private class StatusFormModel
	{
		[Required(ErrorMessage = "Status name is required.")]
		[StringLength(100, MinimumLength = 2, ErrorMessage = "Status name must be between 2 and 100 characters.")]
		public string StatusName { get; set; } = string.Empty;

		[StringLength(500, ErrorMessage = "Status description cannot exceed 500 characters.")]
		public string? StatusDescription { get; set; }
	}

	/// <summary>
	/// Loads the existing status and populates the form.
	/// </summary>
	protected override async Task OnInitializedAsync()
	{
		_isLoadingStatus = true;
		try
		{
			_status = await StatusClient.GetByIdAsync(Id);
			if (_status != null)
			{
				_formModel = new StatusFormModel
				{
					StatusName = _status.StatusName,
					StatusDescription = _status.StatusDescription
				};
			}
		}
		finally
		{
			_isLoadingStatus = false;
		}
	}

	/// <summary>
	/// Handles the form submission by updating the status and navigating to the statuses list.
	/// </summary>
	private async Task HandleSubmit()
	{
		_isSubmitting = true;
		try
		{
			var command = new UpdateStatusCommand
			{
				Id = ObjectId.Parse(Id),
				StatusName = _formModel.StatusName,
				StatusDescription = _formModel.StatusDescription
			};
			await StatusClient.UpdateAsync(Id, command);
			Nav.NavigateTo("/statuses");
		}
		finally
		{
			_isSubmitting = false;
		}
	}
}
