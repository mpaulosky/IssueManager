@page "/issues/create"

@attribute [Authorize]
@inject IIssueApiClient IssueClient
@inject NavigationManager Nav

<PageTitle>Create Issue — IssueManager</PageTitle>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
	<div class="mb-6">
		<h1 class="page-title mb-2">Create Issue</h1>
		<p class="text-[var(--text-muted)] text-sm">Fill in the details below to create a new issue.</p>
	</div>

	<IssueForm OnSubmit="HandleSubmit" IsSubmitting="_isSubmitting" />
</div>

@code {
	private bool _isSubmitting = false;

	/// <summary>
	/// Handles the form submission by creating a new issue and navigating to the issues list.
	/// </summary>
	private async Task HandleSubmit(CreateIssueRequest request)
	{
		_isSubmitting = true;
		try
		{
			var command = new CreateIssueCommand
			{
				Title = request.Title,
				Description = request.Description
			};
			await IssueClient.CreateAsync(command);
			Nav.NavigateTo("/issues");
		}
		finally
		{
			_isSubmitting = false;
		}
	}
}
