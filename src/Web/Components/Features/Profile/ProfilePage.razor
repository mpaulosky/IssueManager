@page "/profile"

@attribute [Authorize]
@inject NavigationManager Nav

<PageTitle>My Profile — IssueManager</PageTitle>

<div class="max-w-5xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="flex items-center justify-between mb-6">
        <h1 class="page-title">@_userName's Profile</h1>
        <button @onclick="@(() => Nav.NavigateTo("/"))" class="link-back">
            ← Back
        </button>
    </div>

    @if (_isLoading)
    {
        <div class="loading-state">Loading...</div>
    }
    else
    {
        @if (_approved.Any())
        {
            <div class="mb-8">
                <h2 class="section-title mb-3">Approved Issues</h2>
                <p class="text-sm text-[var(--text-muted)] mb-4">These are your issues currently available for comment.</p>
                <div class="space-y-3">
                    @foreach (var item in _approved)
                    {
                        <IssueCard Item="item" />
                    }
                </div>
            </div>
        }

        @if (_pending.Any())
        {
            <div class="mb-8">
                <h2 class="section-title mb-3">Pending Issues</h2>
                <p class="text-sm text-[var(--text-muted)] mb-4">These are your issues under review.</p>
                <div class="space-y-3">
                    @foreach (var item in _pending)
                    {
                        <IssueCard Item="item" />
                    }
                </div>
            </div>
        }

        @if (_rejected.Any())
        {
            <div class="mb-8">
                <h2 class="section-title mb-3">Rejected Issues</h2>
                <p class="text-sm text-[var(--text-muted)] mb-4">These issues were not in scope.</p>
                <div class="space-y-3">
                    @foreach (var item in _rejected)
                    {
                        <IssueCard Item="item" />
                    }
                </div>
            </div>
        }

        @if (!_approved.Any() && !_pending.Any() && !_rejected.Any())
        {
            <div class="card text-center text-[var(--text-muted)]">
                You have not submitted any issues yet. <a href="/issues/create" class="link-primary">Create one now</a>.
            </div>
        }
    }
</div>
