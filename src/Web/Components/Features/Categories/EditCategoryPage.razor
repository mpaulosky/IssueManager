@page "/categories/{Id}/edit"

@attribute [Authorize(Roles = "Admin")]
@inject ICategoryApiClient CategoryClient
@inject NavigationManager Nav

<PageTitle>Edit Category — IssueManager</PageTitle>

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
	@if (_isLoadingCategory)
	{
		<LoadingSpinner />
	}
	else if (_category == null)
	{
		<div class="loading-state">
			<p class="text-lg mb-4">Category not found.</p>
			<a href="/categories" class="link-primary">Back to Categories</a>
		</div>
	}
	else
	{
		<div class="mb-6">
			<h1 class="page-title mb-2">Edit Category</h1>
			<p class="text-[var(--text-muted)] text-sm">Update the category details below.</p>
		</div>

		<div class="card">
			<EditForm Model="@_formModel" OnValidSubmit="@HandleSubmit">
				<DataAnnotationsValidator />
				<ValidationSummary class="validation-summary" />

				<div class="space-y-5">
					<!-- Name -->
					<div>
						<label for="category-name" class="form-label">
							Name <span class="text-red-500" aria-hidden="true">*</span>
						</label>
						<InputText id="category-name" @bind-Value="_formModel.CategoryName" class="form-input"
											 placeholder="Enter category name" aria-required="true" />
						<ValidationMessage For="@(() => _formModel.CategoryName)" class="validation-message" />
					</div>

					<!-- Description -->
					<div>
						<label for="category-description" class="form-label">
							Description
						</label>
						<InputTextArea id="category-description" @bind-Value="_formModel.CategoryDescription"
													 class="form-input resize-y" rows="3" placeholder="Enter category description (optional)" />
						<ValidationMessage For="@(() => _formModel.CategoryDescription)" class="validation-message" />
					</div>
				</div>

				<!-- Actions -->
				<div class="mt-6 flex items-center gap-3">
					<button type="submit" class="btn-action" disabled="@_isSubmitting">
						@(_isSubmitting ? "Updating..." : "Update Category")
					</button>
					<a href="/categories" class="btn-ghost">
						Cancel
					</a>
				</div>
			</EditForm>
		</div>
	}
</div>

@code {
	/// <summary>
	/// The ID of the category to edit.
	/// </summary>
	[Parameter]
	public string Id { get; set; } = "";

	private CategoryDto? _category;
	private CategoryFormModel _formModel = new();
	private bool _isLoadingCategory = true;
	private bool _isSubmitting = false;

	private class CategoryFormModel
	{
		[Required(ErrorMessage = "Category name is required.")]
		[StringLength(100, MinimumLength = 2, ErrorMessage = "Category name must be between 2 and 100 characters.")]
		public string CategoryName { get; set; } = string.Empty;

		[StringLength(500, ErrorMessage = "Category description cannot exceed 500 characters.")]
		public string? CategoryDescription { get; set; }
	}

	/// <summary>
	/// Loads the existing category and populates the form.
	/// </summary>
	protected override async Task OnInitializedAsync()
	{
		_isLoadingCategory = true;
		try
		{
			_category = await CategoryClient.GetByIdAsync(Id);
			if (_category != null)
			{
				_formModel = new CategoryFormModel
				{
					CategoryName = _category.CategoryName,
					CategoryDescription = _category.CategoryDescription
				};
			}
		}
		finally
		{
			_isLoadingCategory = false;
		}
	}

	/// <summary>
	/// Handles the form submission by updating the category and navigating to the categories list.
	/// </summary>
	private async Task HandleSubmit()
	{
		_isSubmitting = true;
		try
		{
			var command = new UpdateCategoryCommand
			{
				Id = ObjectId.Parse(Id),
				CategoryDescription = _formModel.CategoryDescription
			};
			await CategoryClient.UpdateAsync(Id, command);
			Nav.NavigateTo("/categories");
		}
		finally
		{
			_isSubmitting = false;
		}
	}
}
