@inject IJSRuntime JS

<button
	@onclick="ToggleDarkMode"
	class="inline-flex items-center justify-center w-9 h-9 rounded-lg text-[var(--text-muted)] hover:bg-[var(--bg-hover)] transition-colors focus:outline-none focus:ring-2 focus:ring-[var(--color-primary)]"
	title="@(_isDark ? "Switch to light mode" : "Switch to dark mode")"
	aria-label="@(_isDark ? "Switch to light mode" : "Switch to dark mode")"
	aria-pressed="@_isDark">
	@if (_isDark)
	{
		<!-- Sun icon (click to go light) -->
		<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
				d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364-6.364l-.707.707M6.343 17.657l-.707.707M17.657 17.657l-.707-.707M6.343 6.343l-.707-.707M12 7a5 5 0 100 10A5 5 0 0012 7z" />
		</svg>
	}
	else
	{
		<!-- Moon icon (click to go dark) -->
		<svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24" aria-hidden="true">
			<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
				d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
		</svg>
	}
</button>

@code {
	private bool _isDark = false;

	/// <summary>
	/// Reads the saved dark-mode preference from localStorage on first render.
	/// </summary>
	protected override async Task OnAfterRenderAsync(bool firstRender)
	{
		if (firstRender)
		{
			try
			{
				_isDark = await JS.InvokeAsync<bool>("themeHelpers.isDark");
				await InvokeAsync(StateHasChanged);
			}
			catch (JSException)
			{
				// JS not ready, default to light mode
			}
		}
	}

	private async Task ToggleDarkMode()
	{
		_isDark = !_isDark;
		await JS.InvokeVoidAsync("themeHelpers.setDark", _isDark);
	}
}
